{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eve",
  "version": "0.1.0",
  "identifier": "com.eve.dictation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Eve",
        "url": "index.html",
        "width": 920,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "visible": true
      },
      {
        "label": "flowbar",
        "url": "flowbar.html",
        "width": 280,
        "height": 92,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/audio/*", "$APPLOCALDATA/audio/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
